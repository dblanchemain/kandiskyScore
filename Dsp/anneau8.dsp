declare name        "anneau8";
declare version     "1.0";
declare author      "D.Blanchemain";
declare license     "BSD";
declare copyright   "(c)D.Blanchemain 2023";
import("stdfaust.lib");
Matrix(N,M) =_*cdistance<: par(out, M, *(Fader(1,out): si.smoo)) :> par(out, M, _)
with {
tabSpeakerX(1)=-0.5;
tabSpeakerY(1)=0.01;
tabSpeakerZ(1)=0.99;
tabSpeakerD(1)=1.11;
tabSpeakerX(2)=0.5;
tabSpeakerY(2)=0.01;
tabSpeakerZ(2)=0.99;
tabSpeakerD(2)=1.11;
tabSpeakerX(3)=-0.99;
tabSpeakerY(3)=0.01;
tabSpeakerZ(3)=0.4;
tabSpeakerD(3)=1.07;
tabSpeakerX(4)=1;
tabSpeakerY(4)=0.01;
tabSpeakerZ(4)=0.4;
tabSpeakerD(4)=1.08;
tabSpeakerX(5)=-1;
tabSpeakerY(5)=0.01;
tabSpeakerZ(5)=-0.3;
tabSpeakerD(5)=1.04;
tabSpeakerX(6)=1;
tabSpeakerY(6)=0.01;
tabSpeakerZ(6)=-0.3;
tabSpeakerD(6)=1.04;
tabSpeakerX(7)=-0.5;
tabSpeakerY(7)=0.01;
tabSpeakerZ(7)=-0.99;
tabSpeakerD(7)=1.11;
tabSpeakerX(8)=0.5;
tabSpeakerY(8)=0.01;
tabSpeakerZ(8)=-0.98;
tabSpeakerD(8)=1.10;
dtencGen(in, out) = sqrt(pow(tabSpeakerX(out)-x(in),2) + pow(tabSpeakerY(out)+y(in),2) + pow(tabSpeakerZ(out)-z(in),2));
hspot = hslider("Hot Spot",-20,-50,0,1);
dgain(in, out) = ba.db2linear((hspot/tabSpeakerD(out))*dtencGen(in,out));
x(i) = hslider("/X%i",0,-1,1,0.01);
y(i) = hslider("/Y%i",0,-1,1,0.01);
z(i) = hslider("/Z%i",0,-1,1,0.01);
Fader(in,out)= vgroup("[1]Input %2in",dgain(in,out));
cdistance(in)=hslider("dt",1,0,1,0.1):si.smoo;
paramDistance(x)=hgroup("[2]Distance",x);
};
process =_,_:> Matrix(1,8);
