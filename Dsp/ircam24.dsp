tabSpeakerD(10)=0.67;
tabSpeakerX(11)=0.69;
tabSpeakerY(11)=-0.22;
tabSpeakerZ(11)=0.17;
tabSpeakerD(11)=0.74;
tabSpeakerX(12)=0.69;
tabSpeakerY(12)=-0.22;
tabSpeakerZ(12)=-0.37;
tabSpeakerD(12)=0.81;
tabSpeakerX(13)=0.36;
tabSpeakerY(13)=-0.22;
tabSpeakerZ(13)=-0.63;
tabSpeakerD(13)=0.76;
tabSpeakerX(14)=0;
tabSpeakerY(14)=-0.22;
tabSpeakerZ(14)=-0.7;
tabSpeakerD(14)=0.73;
tabSpeakerX(15)=-0.35;
tabSpeakerY(15)=-0.22;
tabSpeakerZ(15)=-0.64;
tabSpeakerD(15)=0.76;
tabSpeakerX(16)=-0.69;
