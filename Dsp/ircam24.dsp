tabSpeakerD(17)=0.75;
tabSpeakerX(18)=-0.37;
tabSpeakerY(18)=-0.22;
tabSpeakerZ(18)=0.6;
tabSpeakerD(18)=0.74;
tabSpeakerX(19)=-0.15;
tabSpeakerY(19)=0.4;
tabSpeakerZ(19)=0.34;
tabSpeakerD(19)=0.55;
tabSpeakerX(20)=0.3;
tabSpeakerY(20)=0.4;
tabSpeakerZ(20)=-0.17;
tabSpeakerD(20)=0.53;
tabSpeakerX(21)=-0.05;
tabSpeakerY(21)=0.4;
tabSpeakerZ(21)=-0.35;
tabSpeakerD(21)=0.53;
tabSpeakerX(22)=-0.35;
tabSpeakerY(22)=0.4;
tabSpeakerZ(22)=-0.01;
tabSpeakerD(22)=0.53;
tabSpeakerX(23)=0;
tabSpeakerY(23)=1;
tabSpeakerZ(23)=0;
tabSpeakerD(23)=1.00;
tabSpeakerX(24)=0.28;
tabSpeakerY(24)=0.4;
tabSpeakerZ(24)=0.27;
tabSpeakerD(24)=0.56;
dtencGen(in, out) = sqrt(pow(tabSpeakerX(out)-x(in),2) + pow(tabSpeakerY(out)+y(in),2) + pow(tabSpeakerZ(out)-z(in),2));
hspot = hslider("Hot Spot",-20,-50,0,1);
dgain(in, out) = ba.db2linear((hspot/tabSpeakerD(out))*dtencGen(in,out));
x(i) = hslider("/X%i",0,-1,1,0.01);
y(i) = hslider("/Y%i",0,-1,1,0.01);
z(i) = hslider("/Z%i",0,-1,1,0.01);
Fader(in,out)= vgroup("[1]Input %2in",dgain(in,out));
cdistance(in)=hslider("dt",1,0,1,0.1):si.smoo;
paramDistance(x)=hgroup("[2]Distance",x);
};
process =_,_:> Matrix(1,24);
