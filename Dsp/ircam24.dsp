declare name        "ircam24";
declare version     "1.0";
declare author      "D.Blanchemain";
declare license     "BSD";
declare copyright   "(c)D.Blanchemain 2023";
import("stdfaust.lib");
Matrix(N,M) =_*cdistance<: par(out, M, *(Fader(1,out): si.smoo)) :> par(out, M, _)
with {
tabSpeakerX(1)=0.01;
tabSpeakerY(1)=-0.6;
tabSpeakerZ(1)=1;
tabSpeakerD(1)=1.17;
tabSpeakerX(2)=0.77;
tabSpeakerY(2)=-0.6;
tabSpeakerZ(2)=0.6;
tabSpeakerD(2)=1.15;
tabSpeakerX(3)=1;
