declare name        "auro170";
declare version     "1.0";
declare author      "D.Blanchemain";
declare license     "BSD";
declare copyright   "(c)D.Blanchemain 2023";
import("stdfaust.lib");
Matrix(N,M) =_*cdistance<: par(out, M, *(Fader(1,out): si.smoo)) :> par(out, M, _)
with {
tabSpeakerX(1)=-1;
tabSpeakerY(1)=-0.69;
tabSpeakerZ(1)=1;
tabSpeakerD(1)=1.57;
tabSpeakerX(2)=-0.5;
tabSpeakerY(2)=-0.69;
tabSpeakerZ(2)=0.99;
tabSpeakerD(2)=1.31;
tabSpeakerX(3)=-0.01;
tabSpeakerY(3)=-0.69;
tabSpeakerZ(3)=1;
tabSpeakerD(3)=1.21;
tabSpeakerX(4)=0.5;
tabSpeakerY(4)=-0.69;
tabSpeakerZ(4)=1;
tabSpeakerD(4)=1.31;
tabSpeakerX(5)=1;
tabSpeakerY(5)=-0.69;
tabSpeakerZ(5)=0.99;
tabSpeakerD(5)=1.57;
tabSpeakerX(6)=-1;
tabSpeakerY(6)=-0.69;
tabSpeakerZ(6)=0;
tabSpeakerD(6)=1.21;
tabSpeakerX(7)=1;
tabSpeakerY(7)=-0.69;
tabSpeakerZ(7)=0;
tabSpeakerD(7)=1.21;
tabSpeakerX(8)=-1;
tabSpeakerY(8)=-0.69;
tabSpeakerZ(8)=-1;
tabSpeakerD(8)=1.57;
tabSpeakerX(9)=0;
tabSpeakerY(9)=-0.69;
tabSpeakerZ(9)=-1;
tabSpeakerD(9)=1.21;
tabSpeakerX(10)=1;
tabSpeakerY(10)=-0.69;
tabSpeakerZ(10)=-1;
tabSpeakerD(10)=1.57;
tabSpeakerX(11)=-1;
tabSpeakerY(11)=0.66;
tabSpeakerZ(11)=1;
tabSpeakerD(11)=1.56;
tabSpeakerX(12)=0;
tabSpeakerY(12)=0.66;
tabSpeakerZ(12)=1;
tabSpeakerD(12)=1.20;
tabSpeakerX(13)=1;
tabSpeakerY(13)=0.66;
tabSpeakerZ(13)=1;
tabSpeakerD(13)=1.56;
tabSpeakerX(14)=-1;
tabSpeakerY(14)=0.66;
tabSpeakerZ(14)=-1;
tabSpeakerD(14)=1.56;
tabSpeakerX(15)=0;
tabSpeakerY(15)=0.66;
tabSpeakerZ(15)=-1;
tabSpeakerD(15)=1.20;
tabSpeakerX(16)=1;
tabSpeakerY(16)=0.66;
tabSpeakerZ(16)=-1;
tabSpeakerD(16)=1.56;
tabSpeakerX(17)=0;
tabSpeakerY(17)=0.99;
tabSpeakerZ(17)=0;
tabSpeakerD(17)=0.99;
dtencGen(in, out) = sqrt(pow(tabSpeakerX(out)-x(in),2) + pow(tabSpeakerY(out)+y(in),2) + pow(tabSpeakerZ(out)-z(in),2));
hspot = hslider("Hot Spot",-20,-50,0,1);
dgain(in, out) = ba.db2linear((hspot/tabSpeakerD(out))*dtencGen(in,out));
x(i) = hslider("/X%i",0,-1,1,0.01);
y(i) = hslider("/Y%i",0,-1,1,0.01);
z(i) = hslider("/Z%i",0,-1,1,0.01);
Fader(in,out)= vgroup("[1]Input %2in",dgain(in,out));
cdistance(in)=hslider("dt",1,0,1,0.1):si.smoo;
paramDistance(x)=hgroup("[2]Distance",x);
};
process =_,_:> Matrix(1,17);
